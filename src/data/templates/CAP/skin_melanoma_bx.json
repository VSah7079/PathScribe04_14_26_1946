
{
  "protocol": {
    "id": "skin_invasive_melanoma_biopsy",
    "name": "Protocol for the Examination of Biopsy Specimens from Patients with Invasive Melanoma of the Skin",
    "version": "1.1.0.0",
    "master_notes": {
      "A": {
        "id": "A",
        "title": "Procedure",
        "text": "Optimal pathologic evaluation of melanocytic lesions requires complete excision that incorporates the full thickness of the lesion removed intact. \"Shave\" procedures that do not include the intact base of the lesion are suboptimal for pathologic evaluation and should be avoided unless clinically indicated."
      },
      "B": {
        "id": "B",
        "title": "Anatomic Tumor Site",
        "text": "For cutaneous melanoma, prognosis may be affected by primary anatomic site. Prognostic factors analysis of 17,600 melanoma patients validated the American Joint Committee on Cancer melanoma staging system."
      },
      "C": {
        "id": "C",
        "title": "Melanoma Histologic Subtypes",
        "text": "The recent WHO 2018 classification introduced multidimensional pathway classification of melanocytic tumors based on the extent of ultraviolet radiation damage, the cell of origin, and characteristic genomic findings. This was further refined in the WHO 2023 beta version."
      },
      "D": {
        "id": "D",
        "title": "Primary Tumor (Breslow) Thickness and Anatomic (Clark) Levels",
        "text": "Maximum tumor thickness is measured with a calibrated ocular micrometer at a right angle to the surface of the lesion at the point of measurement. The upper point of reference is the upper edge of the granular layer of the epidermis of the overlying skin (if intact) or the base of the ulcer, if the lesion is ulcerated."
      },
      "E": {
        "id": "E",
        "title": "Ulceration",
        "text": "Primary tumor ulceration has been shown to be a dominant independent prognostic factor in invasive cutaneous melanoma. Melanoma ulceration is defined as a full-thickness epidermal defect with evidence of reactive changes such as fibrin deposition and neutrophils."
      },
      "F": {
        "id": "F",
        "title": "Mitotic Rate",
        "text": "Tumor mitotic rate of the invasive component of a melanoma is a strong independent predictor of outcome across its dynamic range in all pT categories. The recommended approach is to first find the regions in the invasive melanoma within dermis containing the most mitotic figures, the so-called 'hot spot'."
      },
      "G": {
        "id": "G",
        "title": "Satellite(s)",
        "text": "A microsatellite is defined as the presence of a microscopic discontinuous focus of melanoma adjacent or deep to a primary melanoma on pathological examination of the primary tumor site. The metastatic tumor cells must be discontinuous from the primary tumor and separated from the primary tumor by normal stroma."
      },
      "H": {
        "id": "H",
        "title": "Lymphatic and/or Vascular Invasion",
        "text": "Lymphovascular invasion is identified by the demonstration of melanoma cells within the lumina of blood vessels or lymphatics, or both. Vascular invasion by melanoma correlates independently with worsened overall survival."
      },
      "I": {
        "id": "I",
        "title": "Neurotropism",
        "text": "Neurotropism is defined as the presence of melanoma cells abutting nerve sheaths usually circumferentially (perineural invasion) or within nerves (intraneural invasion). Occasionally, the tumor itself may form neuroid structures termed 'neural transformation'."
      },
      "J": {
        "id": "J",
        "title": null,
        "text": null
      },
      "K": {
        "id": "K",
        "title": null,
        "text": null
      },
      "L": {
        "id": "L",
        "title": null,
        "text": null
      },
      "M": {
        "id": "M",
        "title": null,
        "text": null
      }
    },
